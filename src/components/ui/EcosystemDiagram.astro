---
/**
 * CoreProblemStats — Animated stat blocks that communicate the agricultural
 * ecosystem's broken state through stark, large numbers.
 * Numbers are immediately scannable and need no explanation.
 * Pure CSS animations.
 */
---

<div class="cps-grid">

  <div class="cps-card cps-card-1">
    <div class="cps-number-wrap">
      <span class="cps-number">140M<span class="cps-plus">+</span></span>
    </div>
    <p class="cps-label">Farm workers with no digital identity, no income proof, no financial access.</p>
    <div class="cps-accent-line"></div>
  </div>

  <div class="cps-card cps-card-2">
    <div class="cps-number-wrap">
      <span class="cps-number cps-zero">0</span>
    </div>
    <p class="cps-label">Shared systems connecting farmers, workers, machines, and input sellers.</p>
    <div class="cps-accent-line"></div>
  </div>

  <div class="cps-card cps-card-3">
    <div class="cps-number-wrap">
      <span class="cps-number">100<span class="cps-pct">%</span></span>
    </div>
    <p class="cps-label">Coordination still runs on word of mouth and guesswork.</p>
    <div class="cps-accent-line"></div>
  </div>

  <div class="cps-card cps-card-4">
    <div class="cps-number-wrap">
      <span class="cps-number cps-zero">₹0</span>
    </div>
    <p class="cps-label">Formal records per worker — no credit, insurance, or proof of work.</p>
    <div class="cps-accent-line"></div>
  </div>

</div>

<style>
  .cps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin: 1rem 0 0;
  }

  .cps-card {
    position: relative;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 20px;
    padding: 2.5rem 2rem;
    overflow: hidden;
    opacity: 0;
    transform: translateY(24px);
    animation: cpsIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    transition: border-color 0.3s ease, background 0.3s ease;
  }

  .cps-card:hover {
    border-color: rgba(163, 230, 53, 0.2);
    background: rgba(255, 255, 255, 0.06);
  }

  .cps-card-1 { animation-delay: 0.1s; }
  .cps-card-2 { animation-delay: 0.25s; }
  .cps-card-3 { animation-delay: 0.4s; }
  .cps-card-4 { animation-delay: 0.55s; }

  @keyframes cpsIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .cps-number-wrap {
    margin-bottom: 1.25rem;
  }

  .cps-number {
    font-family: var(--font-heading, 'Outfit', sans-serif);
    font-size: clamp(3rem, 5vw, 4.5rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.04em;
    color: #ffffff;
    display: inline-block;
  }

  .cps-zero {
    color: #A3E635;
  }

  .cps-plus, .cps-pct {
    font-size: 0.5em;
    color: rgba(255, 255, 255, 0.35);
    font-weight: 800;
    vertical-align: super;
    margin-left: 2px;
  }

  .cps-label {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.55;
    margin: 0;
  }

  /* Accent line at bottom */
  .cps-accent-line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(to right, #A3E635, transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .cps-card:hover .cps-accent-line {
    opacity: 1;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .cps-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .cps-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .cps-card {
      padding: 2rem 1.5rem;
    }
    .cps-number {
      font-size: 3rem;
    }
  }
</style>
