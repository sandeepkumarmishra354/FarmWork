---
import Layout from '../layouts/Layout.astro';
import { Network, Search, Briefcase, Users, Cog, Store, FileText, Wallet, LineChart } from 'lucide-react';
import { getPath } from '../utils/paths';
---

<Layout title="Vision | About FarmWork">
  
  <section style="min-height: 100vh; padding: 12rem 0 8rem 0; background: var(--surface-color); display: flex; align-items: center; justify-content: center;">
    <div class="container fade-up">
      
      {/* Center Aligned Editorial Header */}
      <div style="margin-bottom: 6rem; max-width: 800px;">
        <p style="font-weight: 700; font-size: 0.85rem; letter-spacing: 2px; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem;">
          We're building
        </p>
        <h2 style="font-family: var(--font-heading); font-size: clamp(3rem, 5vw, 4rem); font-weight: 900; line-height: 1; color: var(--text-primary); margin-bottom: 1.5rem; letter-spacing: -0.02em;">
          The digital infrastructure layer for farm work.
        </h2>
        <p style="font-size: 1.25rem; color: var(--text-secondary); line-height: 1.6; max-width: 650px;">
          One platform that connects every stakeholder in the agricultural ecosystem — and records every interaction as structured, valuable data.
        </p>
      </div>

      {/* Symmetrical Premium Grid */}
      <div class="identical-grid">
        
        {/* Card 1 */}
        <div class="bento-item identical-card">
          <p class="card-watermark">01</p>
          <div class="card-icon-box">
            <Users size={24} color="var(--primary)" />
          </div>
          <h3>Real-Time Labour Access</h3>
          <p class="desc">Farmers connect with verified worker agents for specific farm tasks — from land preparation to post-harvest — right when they need them.</p>
        </div>
        
        {/* Card 2 */}
        <div class="bento-item identical-card">
          <p class="card-watermark">02</p>
          <div class="card-icon-box">
            <Cog size={24} color="var(--primary)" />
          </div>
          <h3>Mechanisation as a Service</h3>
          <p class="desc">Crop and geography-based clusters connect farmers with machinery providers. No ownership, no capital risk — access when needed.</p>
        </div>

        {/* Card 3 */}
        <div class="bento-item identical-card">
           <p class="card-watermark">03</p>
           <div class="card-icon-box">
             <Store size={24} color="var(--primary)" />
           </div>
           <h3>Input Partner Network</h3>
           <p class="desc">Farmers check product availability from local retailers digitally. Retailers manage sales, track balances, and reach more farmers.</p>
        </div>

        {/* Card 4 */}
        <div class="bento-item identical-card">
           <p class="card-watermark">04</p>
           <div class="card-icon-box">
             <FileText size={24} color="var(--primary)" />
           </div>
           <h3>Digital Record Keeping</h3>
           <p class="desc">Every farm activity — labour deployed, inputs purchased, machinery used — is recorded. Farmers get cost-of-production intelligence automatically.</p>
        </div>

        {/* Card 5 */}
        <div class="bento-item identical-card">
          <p class="card-watermark">05</p>
          <div class="card-icon-box">
            <Wallet size={24} color="var(--primary)" />
          </div>
          <h3>Financial Identity for Workers</h3>
          <p class="desc">Work history, payment records, and income proof for every farm worker — enabling access to credit, insurance, and formal financial services.</p>
        </div>

        {/* Card 6 */}
        <div class="bento-item identical-card">
          <p class="card-watermark">06</p>
          <div class="card-icon-box">
            <LineChart size={24} color="var(--primary)" />
          </div>
          <h3>Market Linkage & Output Intelligence</h3>
          <p class="desc">Farmers connect with buyers early. Output players gain forward visibility on production volumes, quality, and geography.</p>
        </div>

      </div>

    </div>
  </section>

</Layout>

<style>
  .identical-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .identical-card {
    background: #ffffff;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding: 2.5rem;
    transition: transform 0.3s ease;
  }

  .identical-card:hover {
    transform: translateY(-4px);
  }

  .card-watermark {
    font-family: var(--font-heading);
    font-size: 5.5rem;
    font-weight: 900;
    line-height: 0.8;
    color: var(--primary);
    opacity: 0.05;
    position: absolute;
    right: 1.5rem;
    top: 1.5rem;
    pointer-events: none;
    margin: 0;
  }

  .card-icon-box {
    margin-bottom: 3rem;
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: var(--bg-color);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--surface-border);
  }

  .identical-card h3 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    line-height: 1.25;
    color: var(--text-primary);
    position: relative;
    z-index: 10;
  }

  .identical-card p.desc {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.6;
    position: relative;
    z-index: 10;
  }

  /* Mobile Responsiveness */
  @media (max-width: 1024px) {
    .identical-grid { 
      grid-template-columns: repeat(2, 1fr); 
    }
  }

  @media (max-width: 768px) {
    .identical-grid { 
      grid-template-columns: 1fr; 
    }
    .identical-card {
      padding: 2rem;
    }
    .card-icon-box {
      margin-bottom: 2rem;
    }
  }
</style>
