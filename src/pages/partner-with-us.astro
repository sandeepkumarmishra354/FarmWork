---
import Layout from "../layouts/Layout.astro";
import {
  Cpu,
  Tractor,
  Package,
  Landmark,
  ShieldCheck,
  LineChart,
  Building,
  Lightbulb,
  TrendingUp,
  Briefcase,
  Search,
  Settings,
  Shield,
  ArrowRight,
} from "lucide-react";
import { getPath } from "../utils/paths";
import AmbassadorFlow from "../components/ui/AmbassadorFlow.astro";
---

<Layout
  title="Partner With Us | Ecosystem Collaboration - FarmWork"
  description="FarmWork's community is a structured, growing network of farmers, workers, and service providers. Collaborate with us."
  canonicalPath="/partner-with-us"
  pageType="CollectionPage"
  keywords={[
    "agritech partnership India",
    "agriculture investor India",
    "farm mechanisation partner",
    "agri input distribution partner",
    "rural market access India",
    "agri fintech partnership",
    "agricultural insurance partner India",
    "market linkage agriculture partner",
    "government agriculture data partner",
    "agri research institution India",
    "rural agri collaboration",
    "agritech ecosystem India",
    "agriculture startup partnership",
    "farm technology investor India",
    "collaborative agriculture India",
  ]}
>
  {/* HERO SECTION */}
  <section
    style="position: relative; padding: 10rem 0 6rem 0; min-height: 70vh; display: flex; align-items: center; justify-content: center; overflow: hidden; background: var(--bg-color);"
  >
    <div
      style="position: absolute; inset: 0; z-index: 0; opacity: 0.7; mix-blend-mode: luminosity;"
    >
      <img
        src={getPath("/media/farmers.jpeg")}
        alt="Rural Agriculture Background"
        style="width: 100%; height: 100%; object-fit: cover; filter: grayscale(40%);"
      />
      <div style="position: absolute; inset: 0; background: linear-gradient(to top, var(--bg-color) 0%, transparent 60%, var(--bg-color) 100%);"></div>
      <div style="position: absolute; inset: 0; background: linear-gradient(to right, var(--bg-color) 0%, transparent 50%, var(--bg-color) 100%);"></div>
      <div style="position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(248,250,252,0.75) 0%, transparent 100%);"></div>
    </div>

    <div
      class="container fade-up"
      style="position: relative; z-index: 10; text-align: center; max-width: 1000px;"
    >
      <h1 class="heading-display" style="margin-bottom: 2rem;">
        Collaborate With <span style="color: var(--primary)">Farmwork</span>.
      </h1>
      <p
        style="font-size: 1.35rem; color: var(--text-primary); line-height: 1.6; max-width: 700px; margin: 0 auto;"
      >
        A structured network of farmers, workers, and service providers — built for organisations that want depth, not breadth.
      </p>
    </div>
  </section>

  {/* TABBED HUB SECTION */}
  <section class="tabbed-hub-section">
    <div class="container fade-up delay-1">
      
      {/* Tab Navigation */}
      <div class="tab-nav-wrapper">
        <div class="tab-nav">
          <button class="tab-btn active" data-target="tab-ecosystem">Ecosystem Partners</button>
          <button class="tab-btn" data-target="tab-ambassadors">Village Ambassadors</button>
          <button class="tab-btn" data-target="tab-students">Students & Researchers</button>
        </div>
      </div>

      <div class="tab-content-wrapper">
        
        {/* ── TAB 1: ECOSYSTEM PARTNERS (trimmed) ── */}
        <div class="tab-pane active" id="tab-ecosystem">
          <div class="identical-grid">
            <div class="bento-item identical-card">
              <p class="card-watermark">01</p>
              <div class="card-icon-box"><Cpu size={24} color="var(--primary)" /></div>
              <h3>Agritech & Precision Farming</h3>
              <p class="desc">Test tech within active farmer pilots. Scale through our distribution network.</p>
            </div>
            <div class="bento-item identical-card">
              <p class="card-watermark">02</p>
              <div class="card-icon-box"><Tractor size={24} color="var(--primary)" /></div>
              <h3>Mechanisation Companies</h3>
              <p class="desc">Deploy machinery into geo-clustered demand. We handle aggregation and scheduling.</p>
            </div>
            <div class="bento-item identical-card">
              <p class="card-watermark">03</p>
              <div class="card-icon-box"><Package size={24} color="var(--primary)" /></div>
              <h3>Input & Agrochemical</h3>
              <p class="desc">Reach farmers at the point of need. Get visibility into crop cycles and adoption.</p>
            </div>
            <div class="bento-item identical-card">
              <p class="card-watermark">04</p>
              <div class="card-icon-box"><Landmark size={24} color="var(--primary)" /></div>
              <h3>Financial Institutions</h3>
              <p class="desc">Verifiable income records for 140M+ informal workers. Enable credit access.</p>
            </div>
            <div class="bento-item identical-card">
              <p class="card-watermark">05</p>
              <div class="card-icon-box"><ShieldCheck size={24} color="var(--primary)" /></div>
              <h3>Insurance Companies</h3>
              <p class="desc">Structured agricultural data to design insurance for the historically uninsurable.</p>
            </div>
            <div class="bento-item identical-card">
              <p class="card-watermark">06</p>
              <div class="card-icon-box"><LineChart size={24} color="var(--primary)" /></div>
              <h3>Market Linkage Partners</h3>
              <p class="desc">Forward visibility on production — crop type, output, geography, and timelines.</p>
            </div>
            <div class="bento-item identical-card">
              <p class="card-watermark">07</p>
              <div class="card-icon-box"><Building size={24} color="var(--primary)" /></div>
              <h3>Government Agencies</h3>
              <p class="desc">Ground-level data on agricultural labour and livelihoods for better policy design.</p>
            </div>
            <div class="bento-item identical-card">
              <p class="card-watermark">08</p>
              <div class="card-icon-box"><Lightbulb size={24} color="var(--primary)" /></div>
              <h3>Research Institutions</h3>
              <p class="desc">Access structured, verified datasets from active farming communities across India.</p>
            </div>
            <div class="bento-item identical-card">
              <p class="card-watermark">09</p>
              <div class="card-icon-box"><TrendingUp size={24} color="var(--primary)" /></div>
              <h3>Investors</h3>
              <p class="desc">Early-stage. Building the community, platform, and data layer. Let's build together.</p>
            </div>
          </div>
        </div>

        {/* ── TAB 2: VILLAGE AMBASSADORS (replaced with flow) ── */}
        <div class="tab-pane" id="tab-ambassadors">
          <div class="tab-pane-header text-center" style="max-width: 700px; margin: 0 auto 2rem auto;">
            <p style="font-weight: 700; font-size: 0.85rem; letter-spacing: 2px; text-transform: uppercase; color: var(--primary); margin-bottom: 1.5rem;">
              Village Level Ambassadors
            </p>
            <h2 style="font-family: var(--font-heading); font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 900; line-height: 1.1; margin-bottom: 1.25rem; letter-spacing: -0.02em;">
              Empower your village with Farmwork.
            </h2>
            <p style="font-size: 1.1rem; color: var(--text-secondary); line-height: 1.6;">
              We're looking for local agripreneurs to build and manage Farmwork clusters in their districts.
            </p>
          </div>

          <AmbassadorFlow />
        </div>

        {/* ── TAB 3: STUDENTS & PROFESSIONALS (trimmed) ── */}
        <div class="tab-pane" id="tab-students">
          <div class="tab-pane-header text-center" style="max-width: 700px; margin: 0 auto 2.5rem auto;">
            <p style="font-weight: 700; font-size: 0.85rem; letter-spacing: 2px; text-transform: uppercase; color: var(--primary); margin-bottom: 1.5rem;">
              For Agri Students & Young Professionals
            </p>
            <h2 style="font-family: var(--font-heading); font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 900; line-height: 1.1; margin-bottom: 1.25rem; letter-spacing: -0.02em;">
              Your degree deserves a problem worth solving.
            </h2>
            <p style="font-size: 1.1rem; color: var(--text-secondary); line-height: 1.6;">
              Farmwork is building at the intersection of technology, economics, and ground-level reality.
            </p>
          </div>

          <div class="stats-split">
            <div class="light-card text-center" style="padding: 3rem;">
              <h3 style="font-family: var(--font-heading); font-size: 5rem; font-weight: 900; line-height: 1; color: var(--primary); margin-bottom: 0.75rem;">230M</h3>
              <p style="font-size: 1.05rem; color: var(--text-secondary); line-height: 1.5;">
                Untapped agricultural workforce. We're building systems to formalise their economy.
              </p>
            </div>
            <div class="light-card text-center" style="padding: 3rem; display: flex; flex-direction: column; justify-content: center;">
              <h3 style="font-family: var(--font-heading); font-size: 4rem; font-weight: 900; line-height: 1; color: var(--text-primary); margin-bottom: 0.75rem;">SRAM</h3>
              <p style="font-size: 1.05rem; color: var(--text-secondary); line-height: 1.5;">
                <span style="color: var(--primary); font-weight: bold;">Smart Rural Agri-ecosystem Management</span> — श्रम. A modern system for India's rural workforce.
              </p>
            </div>
          </div>

          <div class="student-grid" style="margin-top: 2rem;">
            <div class="light-card">
              <Briefcase size={28} color="var(--primary)" style={{ marginBottom: "1.5rem" }} />
              <h4 style="font-family: var(--font-heading); font-size: 1.4rem; font-weight: 800; margin-bottom: 0.5rem;">1. Internship</h4>
              <p style="font-weight: 600; color: var(--primary); margin-bottom: 0;">Field & Community Research</p>
            </div>
            <div class="light-card">
              <Settings size={28} color="var(--primary)" style={{ marginBottom: "1.5rem" }} />
              <h4 style="font-family: var(--font-heading); font-size: 1.4rem; font-weight: 800; margin-bottom: 0.5rem;">2. Fellowship</h4>
              <p style="font-weight: 600; color: var(--primary); margin-bottom: 0;">Product & Platform Building</p>
            </div>
            <div class="light-card">
              <Search size={28} color="var(--primary)" style={{ marginBottom: "1.5rem" }} />
              <h4 style="font-family: var(--font-heading); font-size: 1.4rem; font-weight: 800; margin-bottom: 0.5rem;">3. Research</h4>
              <p style="font-weight: 600; color: var(--primary); margin-bottom: 0;">Agri Economics & Labour</p>
            </div>
            <div class="light-card">
              <Shield size={28} color="var(--primary)" style={{ marginBottom: "1.5rem" }} />
              <h4 style="font-family: var(--font-heading); font-size: 1.4rem; font-weight: 800; margin-bottom: 0.5rem;">4. Ambassador</h4>
              <p style="font-weight: 600; color: var(--primary); margin-bottom: 0;">Village Level Leadership</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* CTA FOOTER */}
  <section
    style="padding: 6rem 0; background: var(--bg-color); text-align: center; border-top: 1px solid var(--surface-border);"
  >
    <div class="container fade-up delay-1">
      <p
        style="font-weight: 700; font-size: 0.85rem; letter-spacing: 2px; text-transform: uppercase; color: var(--primary); margin-bottom: 1.5rem;"
      >
        Get Involved
      </p>
      <h2 class="heading-xl" style="color: var(--text-primary); margin-bottom: 2rem;">
        India's agriculture needs systems,<br />not sympathy.
      </h2>

      <div
        style="display: flex; gap: 1rem; justify-content: center;"
        class="cta-buttons"
      >
        <a
          href={getPath("/contact")}
          class="btn"
          style="background: var(--primary); color: #ffffff; padding: 1rem 3rem;"
        >
          Partner With Us <ArrowRight
            size={20}
            style={{ marginLeft: "0.5rem" }}
          />
        </a>
        <a
          href={getPath("/contact")}
          class="btn btn-outline"
          style="padding: 1rem 3rem;"
        >
          Become an Ambassador <ArrowRight
            size={20}
            style={{ marginLeft: "0.5rem" }}
          />
        </a>
      </div>
    </div>
  </section>
  
  {/* Tab Interaction Script */}
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('.tab-btn');
      const panes = document.querySelectorAll('.tab-pane');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          tabs.forEach(t => t.classList.remove('active'));
          panes.forEach(p => p.classList.remove('active'));

          tab.classList.add('active');
          const targetId = tab.getAttribute('data-target');
          if (targetId) {
            document.getElementById(targetId)?.classList.add('active');
          }
        });
      });
    });
  </script>
</Layout>

<style>
  /* ── Tab Navigation ── */
  .tabbed-hub-section {
    padding: 2rem 0 6rem 0;
    background: var(--bg-color);
  }

  .tab-nav-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: 4rem;
  }

  .tab-nav {
    display: inline-flex;
    background: var(--surface-color);
    padding: 0.5rem;
    border-radius: 99px;
    border: 1px solid var(--surface-border);
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
  }

  .tab-btn {
    background: transparent;
    border: none;
    padding: 1rem 2rem;
    border-radius: 99px;
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .tab-btn:hover {
    color: var(--text-primary);
  }

  .tab-btn.active {
    background: var(--primary);
    color: #ffffff;
    box-shadow: 0 4px 12px rgba(21, 128, 61, 0.2);
  }

  /* ── Tab Content Area ── */
  .tab-content-wrapper {
    min-height: 500px;
  }

  .tab-pane {
    display: none;
    opacity: 0;
    transform: translateY(20px);
  }

  .tab-pane.active {
    display: block;
    animation: fadeUpTab 0.5s ease forwards;
  }

  @keyframes fadeUpTab {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Light Cards (Unified) ── */
  .light-card {
    background: var(--surface-color);
    border: 1px solid var(--surface-border);
    border-radius: 24px;
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .light-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.05);
  }

  .light-card h3 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .light-card .desc {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .card-icon-box {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: rgba(21, 128, 61, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .bento-item:hover .card-icon-box {
    transform: scale(1.08);
    background: rgba(21, 128, 61, 0.14);
  }

  /* ── Grids ── */
  .identical-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .bento-item {
    background: var(--surface-color);
    border-radius: 24px;
    padding: 2.5rem;
    border: 1px solid var(--surface-border);
    position: relative;
    overflow: hidden;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .bento-item:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 40px rgba(0,0,0,0.05);
  }

  .card-watermark {
    position: absolute;
    top: -10px;
    right: 10px;
    font-family: var(--font-heading);
    font-size: 6rem;
    font-weight: 900;
    color: rgba(21, 128, 61, 0.03);
    line-height: 1;
    z-index: 0;
  }

  .bento-item h3 {
    font-size: 1.35rem;
    margin-bottom: 0.75rem;
    position: relative;
    z-index: 1;
  }

  .bento-item .desc {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    position: relative;
    z-index: 1;
  }

  .bento-item .card-icon-box {
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 1;
  }

  .stats-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .student-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  /* Mobile Responsiveness */
  @media (max-width: 1024px) {
    .identical-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .student-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .tab-nav {
      flex-direction: column;
      width: 100%;
      border-radius: 16px;
    }
    .tab-btn {
      width: 100%;
      border-radius: 12px;
      padding: 1rem;
    }

    .identical-grid {
      grid-template-columns: 1fr;
      gap: 0.875rem;
    }
    .bento-item, .light-card {
      padding: 1.5rem;
    }
    .card-icon-box {
      margin-bottom: 1.25rem;
      width: 44px;
      height: 44px;
    }
    
    .stats-split {
      grid-template-columns: 1fr !important;
      gap: 0.875rem;
    }

    .student-grid {
      grid-template-columns: 1fr !important;
      gap: 0.875rem;
    }

    .cta-buttons {
      flex-direction: column;
      gap: 0.75rem;
    }
    .cta-buttons .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
