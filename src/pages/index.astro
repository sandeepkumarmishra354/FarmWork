---
import Layout from '../layouts/Layout.astro';
import { ArrowUpRight } from 'lucide-react';
---

<Layout title="Home | Reimagined">
  
  {/* Split Hero Section */}
  <section style="min-height: 100vh; padding-top: 8rem; display: flex; align-items: center;">
    <div class="container">
      <div class="grid grid-cols-2" style="align-items: center; gap: 4rem;">
        
        {/* Left Typography */}
        <div class="fade-up">
          <div style="display: inline-block; padding: 0.5rem 1rem; border: 1px solid var(--text-primary); border-radius: 999px; font-weight: 600; margin-bottom: 2rem;">
            FarmWork Platform
          </div>
          <h1 class="heading-display" style="margin-bottom: 2rem; position: relative;">
            The OS for India's <br />
            <span style="display: inline-block; position: relative;">
              Agriculture.
              <svg style="position: absolute; bottom: 10px; left: 0; width: 100%; height: 20px; z-index: -1;" viewBox="0 0 100 20" preserveAspectRatio="none">
                <path d="M0,10 Q50,20 100,5" stroke="var(--accent)" stroke-width="15" fill="none" class="organic-fluid" />
              </svg>
            </span>
          </h1>
          <p style="font-size: 1.5rem; color: var(--text-secondary); margin-bottom: 3rem; max-width: 500px; line-height: 1.5;">
            Say goodbye to delayed operations. We connect farmers, agents, and mechanization partners dynamically.
          </p>
          <div style="display: flex; gap: 1rem;">
            <a href="/features" class="btn btn-primary" style="padding: 1.25rem 2.5rem; font-size: 1.2rem;">
              Explore Solutions
            </a>
          </div>
        </div>

        {/* Right Video Blob */}
        <div class="fade-up delay-1" style="height: 700px; position: relative;">
          <div class="organic-fluid" style="width: 100%; height: 100%; overflow: hidden; position: relative;">
            <video autoplay loop muted playsinline style="width: 100%; height: 100%; object-fit: cover;">
              <source src="/media/vdo-1.mp4" type="video/mp4" />
            </video>
            <div style="position: absolute; inset: 0; background: var(--primary); mix-blend-mode: color; opacity: 0.4;"></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* Bento Box Pillars */}
  <section style="padding: 10rem 0; background: #FFFFFF; position: relative; z-index: 2; border-radius: 64px 64px 0 0; margin-top: -64px;">
    <div class="container">
      <div style="margin-bottom: 5rem;">
        <h2 class="heading-xl">Four Pillars. <br/>One Ecosystem.</h2>
      </div>

      <div class="bento-grid">
        
        {/* Bento Cell 1 - Large Span */}
        <div class="bento-item col-span-2 row-span-2" style="background: var(--bg-color); padding: 0;">
          <div style="position: relative; height: 100%; display: flex; flex-direction: column;">
            <div style="padding: 3rem; flex: 1;">
              <h3 style="font-size: 2.5rem; margin-bottom: 1rem;">Real-time Visibility</h3>
              <p style="font-size: 1.2rem; color: var(--text-secondary); max-width: 400px;">
                Instantly discover available labour and machinery through crop and geography-based clusters.
              </p>
            </div>
            <div style="height: 300px; overflow: hidden; padding: 0 3rem 0 3rem;">
              <img src="/media/img-1.jpeg" style="width: 100%; height: 100%; object-fit: cover; border-radius: 20px 20px 0 0;" alt="Visibility" />
            </div>
          </div>
        </div>

        {/* Bento Cell 2 */}
        <div class="bento-item col-span-2" style="background: var(--primary); color: #fff;">
          <h3 style="font-size: 2rem; margin-bottom: 1rem; color: #fff;">Digital Intelligence</h3>
          <p style="font-size: 1.2rem; opacity: 0.9;">
            Record-keeping turns daily farming activities into powerful insights. Track expenses and output easily.
          </p>
          <div style="position: absolute; bottom: -20px; right: -20px; opacity: 0.2;">
            <svg width="200" height="200" viewBox="0 0 100 100"><circle cx="50" cy="50" r="40" fill="none" stroke="#fff" stroke-width="20"/></svg>
          </div>
        </div>

        {/* Bento Cell 3 */}
        <div class="bento-item">
          <div style="height: 100%; display: flex; flex-direction: column; justify-content: space-between;">
            <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--text-primary); display: flex; align-items: center; justify-content: center; color: #fff; margin-bottom: 2rem;">
              <ArrowUpRight size={20} />
            </div>
            <div>
              <h3 style="font-size: 1.5rem; margin-bottom: 0.5rem;">Market Integration</h3>
              <p style="color: var(--text-secondary);">Connect early with buyers.</p>
            </div>
          </div>
        </div>

        {/* Bento Cell 4 */}
        <div class="bento-item" style="padding: 0;">
          <img src="/media/img-4.jpeg" style="width: 100%; height: 100%; object-fit: cover; filter: grayscale(50%);" alt="Identity" />
          <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.8), transparent); padding: 2rem; display: flex; flex-direction: column; justify-content: flex-end;">
            <h3 style="font-size: 1.5rem; color: #fff;">Financial Identity</h3>
          </div>
        </div>

      </div>
    </div>
  </section>

  {/* CTA Area */}
  <section style="padding: 10rem 0; background: var(--text-primary); color: #fff;">
    <div class="container text-center">
      <h2 class="heading-xl" style="color: #fff; margin-bottom: 2rem;">Ready to digitize <br/><span style="color: var(--accent);">agriculture?</span></h2>
      <a href="/contact" class="btn" style="background: var(--accent); color: var(--text-primary); padding: 1.5rem 3rem; font-size: 1.25rem;">
        Join 140M+ Labourers
      </a>
    </div>
  </section>
</Layout>
