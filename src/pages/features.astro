---
import Layout from '../layouts/Layout.astro';
import FeatureTabs from '../components/ui/FeatureTabs.tsx';
---

<Layout title="Platform Solutions | Interactive">
  
  {/* Hero Section */}
  <section style="padding: 12rem 0 0 0; background: var(--bg-color); text-align: center;">
    <div class="container">
      <div class="fade-up">
        <h1 class="heading-display" style="margin-bottom: 2rem;">
          Mutually<br/>
          <span style="color: var(--primary);">Beneficial.</span>
        </h1>
        <p style="font-size: 1.5rem; color: var(--text-secondary); max-width: 800px; margin: 0 auto;">
          Massive value generation across every node of the ecosystem. Select your segment to explore solutions.
        </p>
      </div>
    </div>
  </section>

  {/* Interactive Tab Dashboard */}
  <section style="padding: 6rem 0 6rem 0; background: var(--bg-color);">
    <div class="container fade-up delay-1">
      <FeatureTabs client:load />
    </div>
  </section>

</Layout>
