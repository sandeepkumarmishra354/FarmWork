---
import Layout from '../layouts/Layout.astro';
import { Mail, Phone, MapPin, Send } from 'lucide-react';
---

<Layout
  title="Contact FarmWork | Partnerships, Collaboration & Inquiries"
  description="Get in touch with FarmWork to explore partnership opportunities, ambassador programs, investor conversations, or agritech collaboration. Reach us to build India's agricultural operating system together."
  canonicalPath="/contact"
  pageType="ContactPage"
  keywords={[
    'contact FarmWork',
    'agritech collaboration India',
    'agriculture partnership inquiry',
    'rural agri startup contact',
    'FarmWork partner inquiry',
    'agritech investor contact India',
    'farm technology partnership',
    'agriculture ambassador program',
    'FarmWork email contact',
    'agri ecosystem collaboration',
  ]}
>
  
  <section style="min-height: 100vh; padding: 10rem 0 6rem 0; background: var(--surface-color); display: flex; align-items: center; justify-content: center;">
    <div class="container">
      
      {/* The Master Contact Card (Dashboard Style) */}
      <div class="fade-up" style="max-width: 1100px; margin: 0 auto; background: #ffffff; border-radius: 40px; overflow: hidden; box-shadow: 0 30px 60px rgba(0,0,0,0.08); display: flex; flex-wrap: wrap; border: 1px solid var(--surface-border);">
        
        {/* Left Side: Dark Information Panel */}
        <div class="contact-info-panel" style="flex: 1; min-width: 350px; background: var(--text-primary); color: #ffffff; padding: 5rem 4rem; position: relative; overflow: hidden;">
          {/* Subtle Background Pattern */}
          <div style="position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 60%); pointer-events: none;"></div>
          
          <div style="position: relative; z-index: 10; height: 100%; display: flex; flex-direction: column;">
            <h2 class="heading-lg" style="color: #fff; margin-bottom: 1rem;">Let's Build <br/><span style="color: var(--primary);">Together.</span></h2>
            <p style="font-size: 1.2rem; color: #cbd5e1; margin-bottom: 4rem; line-height: 1.6;">
              Whether you're a farmer needing machinery, an agent managing a cluster, or a partner seeking integration—drop us a line.
            </p>
            
            <div style="display: flex; flex-direction: column; gap: 2.5rem; margin-top: auto;">
              
              <div style="display: flex; align-items: flex-start; gap: 1.5rem;">
                <div style="width: 48px; height: 48px; background: rgba(255,255,255,0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                  <Mail size={24} color="var(--primary)" />
                </div>
                <div>
                  <p style="font-size: 0.9rem; color: #cbd5e1; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.25rem;">Email Us</p>
                  <p style="font-size: 1.2rem; font-weight: 500;">hello@farmwork.in</p>
                </div>
              </div>

              <div style="display: flex; align-items: flex-start; gap: 1.5rem;">
                <div style="width: 48px; height: 48px; background: rgba(255,255,255,0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                  <Phone size={24} color="var(--primary)" />
                </div>
                <div>
                  <p style="font-size: 0.9rem; color: #cbd5e1; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.25rem;">Call Us</p>
                  <p style="font-size: 1.2rem; font-weight: 500;">+91 1800-FARM-WRK</p>
                </div>
              </div>

              <div style="display: flex; align-items: flex-start; gap: 1.5rem;">
                <div style="width: 48px; height: 48px; background: rgba(255,255,255,0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                  <MapPin size={24} color="var(--primary)" />
                </div>
                <div>
                  <p style="font-size: 0.9rem; color: #cbd5e1; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.25rem;">HQ Location</p>
                  <p style="font-size: 1.2rem; font-weight: 500; line-height: 1.5;">Agri-Tech Campus,<br/>New Delhi, India 110001</p>
                </div>
              </div>

            </div>
          </div>
        </div>

        {/* Right Side: Solid Input Form */}
        <div style="flex: 1.5; min-width: 400px; padding: 5rem 4rem; background: #ffffff;">
          <h3 style="font-size: 1.8rem; font-family: var(--font-heading); color: var(--text-primary); margin-bottom: 2rem;">Send a Message</h3>
          
          <form style="display: flex; flex-direction: column; gap: 1.5rem;">
            
            <div class="grid grid-cols-2 contact-name-grid" style="gap: 1.5rem;">
              <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                <label for="fname" style="font-size: 0.95rem; font-weight: 600; color: var(--text-primary);">First Name</label>
                <input type="text" id="fname" placeholder="John" required class="solid-input" />
              </div>
              <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                <label for="lname" style="font-size: 0.95rem; font-weight: 600; color: var(--text-primary);">Last Name</label>
                <input type="text" id="lname" placeholder="Doe" required class="solid-input" />
              </div>
            </div>

            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
              <label for="email" style="font-size: 0.95rem; font-weight: 600; color: var(--text-primary);">Email Address / Phone</label>
              <input type="text" id="email" placeholder="hello@example.com" required class="solid-input" />
            </div>

            <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1rem;">
              <label style="font-size: 0.95rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem;">I am a...</label>
              <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
                <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 1.05rem; cursor: pointer; color: var(--text-secondary);">
                  <input type="radio" name="role" value="farmer" style="width: 20px; height: 20px; accent-color: var(--primary);" /> Farmer
                </label>
                <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 1.05rem; cursor: pointer; color: var(--text-secondary);">
                  <input type="radio" name="role" value="agent" style="width: 20px; height: 20px; accent-color: var(--primary);" /> Worker Agent
                </label>
                <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 1.05rem; cursor: pointer; color: var(--text-secondary);">
                  <input type="radio" name="role" value="partner" style="width: 20px; height: 20px; accent-color: var(--primary);" /> Mech Partner
                </label>
              </div>
            </div>

            <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-top: 1rem;">
              <label for="message" style="font-size: 0.95rem; font-weight: 600; color: var(--text-primary);">Message details</label>
              <textarea id="message" rows="4" placeholder="How can we help you?" class="solid-input" style="resize: vertical;"></textarea>
            </div>

            <button type="button" class="btn btn-primary" style="margin-top: 2rem; width: 100%; border-radius: 12px; padding: 1.5rem; font-size: 1.2rem; display: flex; align-items: center; justify-content: center; gap: 0.75rem;">
              Send Message <Send size={20} />
            </button>

          </form>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
  /* Solid Input Styling replacing the floating trick */
  .solid-input {
    appearance: none;
    box-sizing: border-box;
    padding: 1.25rem 1.5rem;
    border-radius: 16px;
    border: 2px solid transparent;
    background: #f8fafc;
    font-size: 1.1rem;
    color: var(--text-primary);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    width: 100%;
    font-family: inherit;
  }
  .solid-input::placeholder {
    color: #94a3b8;
    font-weight: 400;
  }
  .solid-input:hover {
    background: #f1f5f9;
  }
  .solid-input:focus {
    outline: none;
    border-color: var(--primary);
    background: #ffffff;
    box-shadow: 0 8px 30px rgba(0,0,0,0.04);
  }

  @media (max-width: 768px) {
    .contact-info-panel {
      min-width: 100% !important;
      padding: 2rem 1.25rem !important;
      border-radius: 0 !important;
    }
    [style*="min-width: 400px"] {
      min-width: 100% !important;
      padding: 2rem 1.25rem !important;
    }
    [style*="border-radius: 40px"] {
      border-radius: 16px !important;
    }
    .contact-name-grid {
      grid-template-columns: 1fr !important;
      gap: 0.875rem !important;
    }
    .solid-input {
      padding: 1rem 1.25rem;
      font-size: 1rem;
      border-radius: 12px;
    }
    [style*="gap: 2.5rem"] {
      gap: 1.5rem !important;
    }
  }

  @media (max-width: 480px) {
    .contact-info-panel {
      padding: 1.75rem 1rem !important;
    }
    [style*="min-width: 400px"] {
      padding: 1.75rem 1rem !important;
    }
    .solid-input {
      padding: 0.875rem 1rem;
      font-size: 0.95rem;
    }
  }
</style>
