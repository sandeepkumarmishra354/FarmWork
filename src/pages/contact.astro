---
import Layout from "../layouts/Layout.astro";
import { getPath } from "../utils/paths";
---

<Layout
  title="Contact FarmWork | Partnerships, Collaboration & Inquiries"
  description="Get in touch with FarmWork to explore partnership opportunities, ambassador programs, investor conversations, or agritech collaboration. Reach us to build India's agricultural operating system together."
  canonicalPath="/contact"
  pageType="ContactPage"
  keywords={[
    "contact FarmWork",
    "agritech collaboration India",
    "agriculture partnership inquiry",
    "rural agri startup contact",
    "FarmWork partner inquiry",
    "agritech investor contact India",
    "farm technology partnership",
    "agriculture ambassador program",
    "FarmWork email contact",
    "agri ecosystem collaboration",
  ]}
>

  <div class="new-contact-page">
    
    <!-- ── BACKGROUND BLOBS ── -->
    <div class="bg-blob blob-1"></div>
    <div class="bg-blob blob-2"></div>

    <div class="container nc-container">

      <!-- ── LEFT: LET'S BUILD TOGETHER (Dark Theme) ── -->
      <div class="nc-left fade-up">
        <div class="nc-left-header">
          <p class="nc-overline">Early Ecosystem</p>
          <h1 class="nc-headline">Let's Build<br/>Together.</h1>
          <p class="nc-intro">
            We're looking to connect with everyone who believes Indian agriculture deserves better infrastructure.
          </p>
        </div>

        <div class="nc-cards">
          <!-- Card 1 -->
          <div class="nc-card fade-up" style="animation-delay: 0.1s;">
            <span class="nc-card-num">01</span>
            <h3>Agritech Startups</h3>
            <p>Solving for inputs, soil health, crop advisory, or farm intelligence — plug into an active farmer network.</p>
          </div>
          <!-- Card 2 -->
          <div class="nc-card fade-up" style="animation-delay: 0.2s;">
            <span class="nc-card-num">02</span>
            <h3>Mechanisation</h3>
            <p>Building next-gen farm equipment — reach geo-clustered demand without building your own distribution layer.</p>
          </div>
          <!-- Card 3 -->
          <div class="nc-card fade-up" style="animation-delay: 0.3s;">
            <span class="nc-card-num">03</span>
            <h3>Agri Enterprises</h3>
            <p>Looking to reach deeper into rural markets — our community and data intelligence takes you there.</p>
          </div>
          <!-- Card 4 -->
          <div class="nc-card fade-up" style="animation-delay: 0.4s;">
            <span class="nc-card-num">04</span>
            <h3>Market Linkage</h3>
            <p>Seeking production visibility — Farmwork's structured data gives you a clear view before the harvest.</p>
          </div>
          <!-- Card 5 -->
          <div class="nc-card nc-card-full fade-up" style="animation-delay: 0.5s;">
            <span class="nc-card-num">05</span>
            <h3>Investors</h3>
            <p>Who see the scale of this problem and the size of the opportunity. Let's build this together.</p>
          </div>
        </div>
      </div>

      <!-- ── RIGHT: CONTACT FORM (Light Theme Glassmorphism) ── -->
      <div class="nc-right fade-up" style="animation-delay: 0.2s;">
        <div class="nc-form-box">
          <div class="nc-form-header">
            <h2>Start a conversation.</h2>
            <p>Tell us about yourself and we'll be in touch shortly.</p>
          </div>

          <!-- Role Chips -->
          <div class="nc-chips-group">
            <p class="nc-chips-label">I'm reaching out as a...</p>
            <div class="nc-chips">
              <label class="nc-chip">
                <input type="radio" name="role" value="partner" />
                <span>Partner</span>
              </label>
              <label class="nc-chip">
                <input type="radio" name="role" value="investor" />
                <span>Investor</span>
              </label>
              <label class="nc-chip">
                <input type="radio" name="role" value="startup" />
                <span>Startup</span>
              </label>
              <label class="nc-chip">
                <input type="radio" name="role" value="ambassador" />
                <span>Ambassador</span>
              </label>
            </div>
          </div>

          <form class="nc-form" novalidate>
            <!-- Name Row -->
            <div class="nc-form-row">
              <div class="float-field">
                <input type="text" id="fname" placeholder=" " required />
                <label for="fname">First Name</label>
                <div class="field-line"></div>
              </div>
              <div class="float-field">
                <input type="text" id="lname" placeholder=" " required />
                <label for="lname">Last Name</label>
                <div class="field-line"></div>
              </div>
            </div>

            <!-- Email & Org -->
            <div class="nc-form-row">
              <div class="float-field">
                <input type="email" id="email" placeholder=" " required />
                <label for="email">Email Address</label>
                <div class="field-line"></div>
              </div>
              <div class="float-field">
                <input type="text" id="org" placeholder=" " />
                <label for="org">Organisation</label>
                <div class="field-line"></div>
              </div>
            </div>

            <!-- Message -->
            <div class="float-field">
              <textarea id="message" rows="4" placeholder=" " required></textarea>
              <label for="message">Your Message</label>
              <div class="field-line"></div>
            </div>

            <button type="submit" class="nc-submit">
              <span>Send Message</span>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
              </svg>
            </button>
            
            <div class="nc-form-footer">
              <a href="mailto:hello@farmworkindia.com" class="nc-direct-email">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
                </svg>
                hello@farmworkindia.com
              </a>
              <span class="nc-dot">•</span>
              <span>Based in India</span>
            </div>
          </form>

        </div>
      </div>

    </div>
  </div>

</Layout>

<style>
  /* ── BASE & BG ── */
  .new-contact-page {
    position: relative;
    background: #f8fafc;
    min-height: 100vh;
    padding: 8rem 0 6rem;
    overflow: hidden;
    z-index: 1;
  }

  /* Ambient Animated Blobs */
  .bg-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    z-index: -1;
    opacity: 0.4;
    animation: floatBlob 15s ease-in-out infinite alternate;
  }
  .blob-1 {
    top: -10%; left: -5%;
    width: 600px; height: 600px;
    background: rgba(163, 230, 53, 0.15); /* Lime */
  }
  .blob-2 {
    bottom: -20%; right: -10%;
    width: 800px; height: 800px;
    background: rgba(21, 128, 61, 0.1); /* Dark Green */
    animation-delay: -5s;
  }

  @keyframes floatBlob {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(30px, 50px) scale(1.1); }
  }

  .nc-container {
    display: flex;
    gap: 4rem;
    align-items: flex-start;
  }

  /* ── LEFT PANEL (Dark Cards) ── */
  .nc-left {
    flex: 1;
    max-width: 580px;
  }

  .nc-left-header {
    margin-bottom: 3rem;
  }

  .nc-overline {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #15803d;
    margin-bottom: 1rem;
  }

  .nc-headline {
    font-family: var(--font-heading, 'Inter', sans-serif);
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #0f172a;
    margin-bottom: 1.25rem;
  }

  .nc-intro {
    font-size: 1.05rem;
    color: #475569;
    line-height: 1.6;
    max-width: 420px;
  }

  .nc-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .nc-card {
    background: #0c1a0e; /* Dark green theme */
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    padding: 1.75rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .nc-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 30px rgba(12, 26, 14, 0.15);
    border-color: rgba(163, 230, 53, 0.2);
  }

  /* Hover glow effect */
  .nc-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 100%;
    background: radial-gradient(circle at 50% 0%, rgba(163, 230, 53, 0.1) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .nc-card:hover::before { opacity: 1; }

  .nc-card-num {
    position: absolute;
    top: -10px; right: -5px;
    font-family: var(--font-heading, 'Inter', sans-serif);
    font-size: 4rem;
    font-weight: 900;
    color: rgba(163, 230, 53, 0.05); /* Watermark lime */
    line-height: 1;
    pointer-events: none;
    transition: transform 0.4s ease;
  }
  .nc-card:hover .nc-card-num {
    transform: scale(1.05) translate(-5px, 5px);
    color: rgba(163, 230, 53, 0.08);
  }

  .nc-card h3 {
    font-family: var(--font-heading, 'Inter', sans-serif);
    font-size: 1.1rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 0.5rem;
    position: relative;
  }

  .nc-card p {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
    margin: 0;
    position: relative;
  }

  .nc-card-full {
    grid-column: 1 / -1;
  }


  /* ── RIGHT PANEL (Light Form Box) ── */
  .nc-right {
    flex: 1;
  }

  .nc-form-box {
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.6);
    border-radius: 24px;
    padding: 3rem;
    box-shadow: 0 10px 40px rgba(0,0,0,0.03), inset 0 1px 0 rgba(255,255,255,1);
  }

  .nc-form-header {
    margin-bottom: 2rem;
  }

  .nc-form-header h2 {
    font-family: var(--font-heading, 'Inter', sans-serif);
    font-size: 1.75rem;
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 0.4rem;
  }

  .nc-form-header p {
    font-size: 0.95rem;
    color: #64748b;
  }

  /* Chips */
  .nc-chips-group {
    margin-bottom: 2rem;
  }

  .nc-chips-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #94a3b8;
    margin-bottom: 1rem;
  }

  .nc-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .nc-chip {
    cursor: pointer;
    position: relative;
    display: inline-flex;
  }

  .nc-chip input {
    position: absolute;
    opacity: 0; width: 0; height: 0;
  }

  .nc-chip span {
    display: inline-flex;
    padding: 0.6rem 1.1rem;
    border-radius: 12px;
    background: #f1f5f9;
    border: 1.5px solid transparent;
    font-size: 0.85rem;
    font-weight: 600;
    color: #64748b;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nc-chip:hover span {
    background: #e2e8f0;
    color: #334155;
  }

  .nc-chip input:checked + span {
    background: #15803d;
    color: #ffffff;
    box-shadow: 0 4px 12px rgba(21, 128, 61, 0.25);
    transform: translateY(-2px);
  }


  /* ── Floating Label Inputs ── */
  .nc-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .nc-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .float-field {
    position: relative;
    background: #f8fafc;
    border-radius: 12px;
    border: 1.5px solid transparent;
    transition: background 0.3s ease;
  }
  
  .float-field:hover {
    background: #f1f5f9;
  }

  .float-field input,
  .float-field textarea {
    width: 100%;
    background: transparent;
    border: none;
    padding: 1.4rem 1.25rem 0.6rem;
    font-family: inherit;
    font-size: 1rem;
    color: #0f172a;
    font-weight: 500;
    outline: none;
    box-sizing: border-box;
  }

  .float-field textarea {
    resize: vertical;
    min-height: 120px;
  }

  /* The floating label */
  .float-field label {
    position: absolute;
    left: 1.25rem;
    top: 1rem;
    font-size: 0.95rem;
    color: #94a3b8;
    pointer-events: none;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: left top;
  }

  /* Animated bottom line */
  .field-line {
    position: absolute;
    bottom: 0; left: 0;
    width: 100%;
    height: 2px;
    background: #15803d;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 0 0 12px 12px;
  }

  /* Active states */
  .float-field input:focus ~ label,
  .float-field input:not(:placeholder-shown) ~ label,
  .float-field textarea:focus ~ label,
  .float-field textarea:not(:placeholder-shown) ~ label {
    transform: translateY(-0.6rem) scale(0.75);
    color: #15803d;
    font-weight: 600;
  }

  .float-field input:focus ~ .field-line,
  .float-field textarea:focus ~ .field-line {
    transform: scaleX(1);
  }

  .float-field:focus-within {
    background: #ffffff;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
  }

  /* Submit */
  .nc-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    padding: 1.25rem;
    margin-top: 1rem;
    background: #15803d;
    color: #ffffff;
    border: none;
    border-radius: 12px;
    font-family: var(--font-heading, 'Inter', sans-serif);
    font-size: 1.1rem;
    font-weight: 800;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s;
  }

  .nc-submit::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 50%; height: 100%;
    background: linear-gradient(to right, transparent, rgba(255,255,255,0.2), transparent);
    transform: skewX(-20deg);
    transition: left 0.5s ease;
  }

  .nc-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(21, 128, 61, 0.3);
  }

  .nc-submit:hover::after {
    left: 150%;
  }

  .nc-submit:active {
    transform: translateY(0);
    box-shadow: none;
  }

  /* Form Footer */
  .nc-form-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: #64748b;
    font-weight: 500;
  }

  .nc-direct-email {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #0f172a;
    text-decoration: none;
    transition: color 0.2s;
  }
  
  .nc-direct-email:hover {
    color: #15803d;
  }

  .nc-dot {
    opacity: 0.4;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 1024px) {
    .nc-container {
      flex-direction: column;
      gap: 4rem;
    }
    .nc-left {
      max-width: 100%;
    }
  }

  @media (max-width: 640px) {
    .new-contact-page {
      padding: 6rem 0 4rem;
    }
    .nc-cards {
      grid-template-columns: 1fr;
    }
    .nc-form-box {
      padding: 2rem 1.5rem;
      border-radius: 20px;
    }
    .nc-form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
