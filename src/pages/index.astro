---
import Layout from "../layouts/Layout.astro";
import { Leaf, Users, ShieldCheck, TrendingUp, HandCoins } from "lucide-react";
---

<Layout title="Home">
  <div class="ambient-glow" style="top: -100px; left: -100px;"></div>

  <section
    style="padding: 12rem 0 6rem 0; min-height: 90vh; display: flex; align-items: center; position: relative;"
  >
    <div class="container animate-fade-in-up">
      <div style="max-width: 800px; margin: 0 auto; text-align: center;">
        <div
          style="display: inline-block; padding: 0.5rem 1rem; background: rgba(16, 185, 129, 0.1); border: 1px solid var(--primary); border-radius: 999px; color: var(--primary); font-weight: 600; margin-bottom: 2rem; font-size: 0.9rem;"
        >
          श्रम · Smart Rural Agri-Work Management
        </div>
        <h1 class="heading-xl" style="margin-bottom: 1.5rem;">
          End-To-End <span class="text-gradient">Farm Work</span> Platform
        </h1>
        <p
          style="font-size: 1.25rem; color: var(--text-secondary); margin-bottom: 3rem; line-height: 1.8;"
        >
          FarmWork connects farmers, labour agents, and mechanization partners.
          Say goodbye to delayed critical farm operations and lack of records.
        </p>
        <div style="display: flex; gap: 1rem; justify-content: center;">
          <a
            href="/contact"
            class="btn btn-primary"
            style="padding: 1rem 2rem; font-size: 1.1rem;"
          >
            Join the Waitlist
          </a>
          <a
            href="/features"
            class="btn btn-outline"
            style="padding: 1rem 2rem; font-size: 1.1rem;"
          >
            Explore Solutions
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* Pillars Section */}
  <section style="padding: 6rem 0; position: relative;">
    <div
      class="ambient-glow"
      style="bottom: 0; right: 0; background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);"
    >
    </div>
    <div class="container">
      <div style="text-align: center; margin-bottom: 4rem;">
        <h2 class="heading-lg" style="margin-bottom: 1rem;">
          The Four Pillars of FarmWork
        </h2>
        <p
          style="color: var(--text-secondary); font-size: 1.1rem; max-width: 600px; margin: 0 auto;"
        >
          Transforming fragmented and informal farming operations into a
          reliable and transparent ecosystem.
        </p>
      </div>

      <div class="grid grid-cols-2">
        <div
          class="glass-card"
          style="display: flex; flex-direction: column; gap: 1rem;"
        >
          <div
            style="width: 50px; height: 50px; border-radius: 12px; background: rgba(16, 185, 129, 0.1); display: flex; align-items: center; justify-content: center; color: var(--primary);"
          >
            <Users size={24} />
          </div>
          <h3 style="font-size: 1.5rem; color: #fff;">Real-time Visibility</h3>
          <p style="color: var(--text-secondary); flex: 1;">
            Instantly discover available labour and machinery through our crop
            and geography-based clusters. Stop relying on uncertain phone calls.
          </p>
        </div>

        <div
          class="glass-card"
          style="display: flex; flex-direction: column; gap: 1rem;"
        >
          <div
            style="width: 50px; height: 50px; border-radius: 12px; background: rgba(217, 245, 67, 0.1); display: flex; align-items: center; justify-content: center; color: var(--accent);"
          >
            <TrendingUp size={24} />
          </div>
          <h3 style="font-size: 1.5rem; color: #fff;">
            Digital Farm Intelligence
          </h3>
          <p style="color: var(--text-secondary); flex: 1;">
            Digital record-keeping turns daily farming activities into powerful
            insights. Track expenses, output, and workforce efficiency easily.
          </p>
        </div>

        <div
          class="glass-card"
          style="display: flex; flex-direction: column; gap: 1rem;"
        >
          <div
            style="width: 50px; height: 50px; border-radius: 12px; background: rgba(16, 185, 129, 0.1); display: flex; align-items: center; justify-content: center; color: var(--primary);"
          >
            <ShieldCheck size={24} />
          </div>
          <h3 style="font-size: 1.5rem; color: #fff;">
            Worker Financial Identity
          </h3>
          <p style="color: var(--text-secondary); flex: 1;">
            Formalize the invisible workforce. Build digital credit records for
            workers to provide access to insurance, loans, and other financial
            services.
          </p>
        </div>

        <div
          class="glass-card"
          style="display: flex; flex-direction: column; gap: 1rem;"
        >
          <div
            style="width: 50px; height: 50px; border-radius: 12px; background: rgba(217, 245, 67, 0.1); display: flex; align-items: center; justify-content: center; color: var(--accent);"
          >
            <HandCoins size={24} />
          </div>
          <h3 style="font-size: 1.5rem; color: #fff;">Market Integration</h3>
          <p style="color: var(--text-secondary); flex: 1;">
            Secure advance output market linkages. Connect early with buyers for
            expected harvests, preventing distress sales post-harvest.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* CTA Section */}
  <section style="padding: 8rem 0; margin-top: 4rem;">
    <div class="container">
      <div
        class="glass"
        style="padding: 4rem 2rem; text-align: center; background: linear-gradient(145deg, rgba(16, 185, 129, 0.05) 0%, rgba(6, 9, 7, 0) 100%); border-color: rgba(16, 185, 129, 0.2);"
      >
        <h2 class="heading-lg" style="margin-bottom: 1.5rem;">
          Ready to digitize agriculture?
        </h2>
        <p
          style="color: var(--text-secondary); font-size: 1.1rem; margin-bottom: 2.5rem; max-width: 600px; margin-left: auto; margin-right: auto;"
        >
          We are building the operating system for India's 140M+ agricultural
          labourers and farmers. Join us in transforming the rural ecosystem.
        </p>
        <a href="/contact" class="btn btn-primary" style="padding: 1rem 2.5rem;"
          >Join as a Partner</a
        >
      </div>
    </div>
  </section>
</Layout>
