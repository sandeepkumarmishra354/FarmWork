---
import { getPath } from "../../utils/paths";
---

<footer
  style="background: #ffffff; border-top: 1px solid var(--surface-border); padding: 4rem 0 2rem 0; margin-top: auto;"
>
  <div
    class="container"
    style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem;"
  >
    <div>
      <a
        href={getPath("/")}
        style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;"
      >
        <span
          style="font-family: var(--font-heading); font-size: 1.5rem; font-weight: 800; color: var(--text-primary);"
        >
          <span style="color: var(--primary);">Farm</span>Work.
        </span>
      </a>
      <p
        style="color: var(--text-secondary); max-width: 300px; margin-bottom: 2rem; line-height: 1.6;"
      >
        The operating system for India's agricultural work economy. Smart Rural
        Agri-Work Management.
      </p>
    </div>

    <div style="display: flex; flex-direction: column; gap: 0.75rem;">
      <h4
        style="color: var(--text-primary); margin-bottom: 0.5rem; font-size: 1.1rem;"
      >
        Platform
      </h4>
      <a
        href={getPath("/")}
        style="color: var(--text-secondary); transition: color 0.2s; text-decoration: none;"
        >Home</a
      >
      <a
        href={getPath("/features")}
        style="color: var(--text-secondary); transition: color 0.2s; text-decoration: none;"
        >Solutions</a
      >
      <a
        href={getPath("/about")}
        style="color: var(--text-secondary); transition: color 0.2s; text-decoration: none;"
        >Vision & Impact</a
      >
    </div>

    <div style="display: flex; flex-direction: column; gap: 0.75rem;">
      <h4
        style="color: var(--text-primary); margin-bottom: 0.5rem; font-size: 1.1rem;"
      >
        Company
      </h4>
      <a
        href="#"
        style="color: var(--text-secondary); transition: color 0.2s; text-decoration: none;"
        >About Us</a
      >
      <a
        href={getPath("/contact")}
        style="color: var(--text-secondary); transition: color 0.2s; text-decoration: none;"
        >Contact Us</a
      >
      <a
        href="#"
        style="color: var(--text-secondary); transition: color 0.2s; text-decoration: none;"
        >Careers</a
      >
    </div>

    <div style="display: flex; flex-direction: column; gap: 0.75rem;">
      <h4
        style="color: var(--text-primary); margin-bottom: 0.5rem; font-size: 1.1rem;"
      >
        Legal
      </h4>
      <a
        href="#"
        style="color: var(--text-secondary); transition: color 0.2s; text-decoration: none;"
        >Privacy Policy</a
      >
      <a
        href="#"
        style="color: var(--text-secondary); transition: color 0.2s; text-decoration: none;"
        >Terms of Service</a
      >
    </div>
  </div>

  <style>
    @media (max-width: 768px) {
      .container[style*="display: grid"] {
        grid-template-columns: 1fr 1fr !important;
      }
      .container[style*="display: grid"] > div:first-child {
        grid-column: span 2;
      }
    }
  </style>

  <div
    class="container"
    style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--surface-border); text-align: center; color: var(--text-secondary); font-size: 0.9rem;"
  >
    &copy; {new Date().getFullYear()} FarmWork. All rights reserved.
  </div>
</footer>
