---
import Layout from '../layouts/Layout.astro';
import { Leaf, Users, ShieldCheck, TrendingUp, HandCoins } from 'lucide-react';
import { FadeIn, StaggerContainer, StaggerItem, HoverScale } from '../components/ui/Animations';
import { AnimatedSun, BlobBackground } from '../components/ui/AgriSVGs';
---

<Layout title="Home">
  {/* Hero Section with Video Background and Light Overlay */}
  <section style="position: relative; padding: 14rem 0 8rem 0; min-height: 100vh; display: flex; align-items: center; overflow: hidden;">
    <BlobBackground client:load />

    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: -2;">
      <video autoplay loop muted playsinline style="width: 100%; height: 100%; object-fit: cover; opacity: 0.3;">
        <source src="/media/vdo-1.mp4" type="video/mp4" />
      </video>
    </div>
    {/* Light frosted overlay */}
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(to bottom, rgba(250, 250, 249, 0.7) 0%, rgba(250, 250, 249, 1) 100%); z-index: -1;"></div>

    <div class="container relative z-10" style="position: relative;">
      {/* Sun animation positioning */}
      <div style="position: absolute; top: -100px; right: 10%; z-index: -1; opacity: 0.5;">
        <AnimatedSun client:load size={200} />
      </div>

      <FadeIn client:load delay={0.2} direction="up" style={{ maxWidth: '800px', margin: '0 auto', textAlign: 'center' }}>
        <div style="display: inline-block; padding: 0.5rem 1rem; background: rgba(255, 255, 255, 0.8); border: 1px solid rgba(22, 163, 74, 0.4); backdrop-filter: blur(8px); border-radius: 999px; color: var(--primary); font-weight: 600; margin-bottom: 2rem; font-size: 0.9rem; box-shadow: 0 4px 20px rgba(0,0,0,0.05);">
          श्रम · Smart Rural Agri-Work Management
        </div>
        <h1 class="heading-xl" style="margin-bottom: 1.5rem; color: var(--text-primary);">
          End-To-End <span class="text-gradient">Agri Work</span> Platform
        </h1>
        <p style="font-size: 1.25rem; color: var(--text-secondary); margin-bottom: 3rem; line-height: 1.8;">
          FarmWork connects farmers, labour agents, and mechanization partners. 
          Say goodbye to delayed critical farm operations and lack of records. 
        </p>
        <div style="display: flex; gap: 1rem; justify-content: center;">
          <HoverScale client:load>
            <a href="/contact" class="btn btn-primary" style="padding: 1rem 2rem; font-size: 1.1rem;">
              Join the Waitlist
            </a>
          </HoverScale>
          <HoverScale client:load>
            <a href="/features" class="btn btn-outline" style="padding: 1rem 2rem; font-size: 1.1rem;">
              Explore Solutions
            </a>
          </HoverScale>
        </div>
      </FadeIn>
    </div>
  </section>

  {/* Visual Break - Landscape Image */}
  <section style="padding: 2rem 0; background: var(--bg-color);">
    <div class="container">
      <FadeIn client:load delay={0.1} direction="up">
        <div style="width: 100%; height: 350px; border-radius: 24px; overflow: hidden; border: 1px solid var(--surface-border); box-shadow: 0 20px 50px rgba(0,0,0,0.05);">
          <img src="/media/img-3.jpeg" alt="Farming machinery and operations" style="width: 100%; height: 100%; object-fit: cover;" />
        </div>
      </FadeIn>
    </div>
  </section>

  {/* Pillars Section */}
  <section style="padding: 8rem 0; position: relative;">
    <div class="container">
      <FadeIn client:load direction="up" style={{ textAlign: 'center', marginBottom: '4rem' }}>
        <h2 class="heading-lg" style="margin-bottom: 1rem;">The Four Pillars of FarmWork</h2>
        <p style="color: var(--text-secondary); font-size: 1.1rem; max-width: 600px; margin: 0 auto;">
          Transforming fragmented and informal farming operations into a reliable and transparent ecosystem.
        </p>
      </FadeIn>

      <StaggerContainer client:visible style={{ display: 'grid', gridTemplateColumns: 'repeat(2, 1fr)', gap: '2rem' }}>
        <StaggerItem client:visible>
          <HoverScale client:load style={{ height: '100%' }}>
            <div class="glass-card" style="display: flex; flex-direction: column; gap: 1rem; height: 100%; overflow: hidden; position: relative; padding-top: 200px;">
              <div style="position: absolute; top: 0; left: 0; width: 100%; height: 180px;">
                <img src="/media/img-1.jpeg" style="width: 100%; height: 100%; object-fit: cover; border-bottom: 1px solid var(--surface-border);" alt="Visibility" />
                <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.9));"></div>
              </div>
              <div style="position: absolute; top: 150px; width: 50px; height: 50px; border-radius: 12px; background: #fff; border: 1px solid var(--surface-border); display: flex; align-items: center; justify-content: center; color: var(--primary); z-index: 2; box-shadow: 0 4px 20px rgba(0,0,0,0.05);">
                <Users size={24} />
              </div>
              <h3 style="font-size: 1.5rem; color: var(--text-primary); position: relative; z-index: 2;">Real-time Visibility</h3>
              <p style="color: var(--text-secondary); flex: 1; position: relative; z-index: 2;">
                Instantly discover available labour and machinery through our crop and geography-based clusters. Stop relying on uncertain phone calls.
              </p>
            </div>
          </HoverScale>
        </StaggerItem>

        <StaggerItem client:visible>
          <HoverScale client:load style={{ height: '100%' }}>
            <div class="glass-card" style="display: flex; flex-direction: column; gap: 1rem; height: 100%; overflow: hidden; position: relative; padding-top: 200px;">
              <div style="position: absolute; top: 0; left: 0; width: 100%; height: 180px;">
                <img src="/media/img-2.jpeg" style="width: 100%; height: 100%; object-fit: cover; border-bottom: 1px solid var(--surface-border);" alt="Intelligence" />
                <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.9));"></div>
              </div>
              <div style="position: absolute; top: 150px; width: 50px; height: 50px; border-radius: 12px; background: #fff; border: 1px solid var(--surface-border); display: flex; align-items: center; justify-content: center; color: var(--accent); z-index: 2; box-shadow: 0 4px 20px rgba(0,0,0,0.05);">
                <TrendingUp size={24} color="#65A30D" />
              </div>
              <h3 style="font-size: 1.5rem; color: var(--text-primary); position: relative; z-index: 2;">Digital Intelligence</h3>
              <p style="color: var(--text-secondary); flex: 1; position: relative; z-index: 2;">
                Digital record-keeping turns daily farming activities into powerful insights. Track expenses, output, and workforce efficiency easily.
              </p>
            </div>
          </HoverScale>
        </StaggerItem>

        <StaggerItem client:visible>
          <HoverScale client:load style={{ height: '100%' }}>
            <div class="glass-card" style="display: flex; flex-direction: column; gap: 1rem; height: 100%; overflow: hidden; position: relative; padding-top: 200px;">
              <div style="position: absolute; top: 0; left: 0; width: 100%; height: 180px;">
                <img src="/media/img-4.jpeg" style="width: 100%; height: 100%; object-fit: cover; border-bottom: 1px solid var(--surface-border);" alt="Identity" />
                <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.9));"></div>
              </div>
              <div style="position: absolute; top: 150px; width: 50px; height: 50px; border-radius: 12px; background: #fff; border: 1px solid var(--surface-border); display: flex; align-items: center; justify-content: center; color: var(--primary); z-index: 2; box-shadow: 0 4px 20px rgba(0,0,0,0.05);">
                <ShieldCheck size={24} />
              </div>
              <h3 style="font-size: 1.5rem; color: var(--text-primary); position: relative; z-index: 2;">Worker Financial Identity</h3>
              <p style="color: var(--text-secondary); flex: 1; position: relative; z-index: 2;">
                Formalize the invisible workforce. Build digital credit records for workers to provide access to insurance, loans, and other financial services.
              </p>
            </div>
          </HoverScale>
        </StaggerItem>

        <StaggerItem client:visible>
          <HoverScale client:load style={{ height: '100%' }}>
            <div class="glass-card" style="display: flex; flex-direction: column; gap: 1rem; height: 100%; overflow: hidden; position: relative; padding-top: 200px;">
              <div style="position: absolute; top: 0; left: 0; width: 100%; height: 180px;">
                <img src="/media/img-5.jpeg" style="width: 100%; height: 100%; object-fit: cover; border-bottom: 1px solid var(--surface-border);" alt="Market" />
                <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.9));"></div>
              </div>
              <div style="position: absolute; top: 150px; width: 50px; height: 50px; border-radius: 12px; background: #fff; border: 1px solid var(--surface-border); display: flex; align-items: center; justify-content: center; color: var(--accent); z-index: 2; box-shadow: 0 4px 20px rgba(0,0,0,0.05);">
                <HandCoins size={24} color="#65A30D" />
              </div>
              <h3 style="font-size: 1.5rem; color: var(--text-primary); position: relative; z-index: 2;">Market Integration</h3>
              <p style="color: var(--text-secondary); flex: 1; position: relative; z-index: 2;">
                Secure advance output market linkages. Connect early with buyers for expected harvests, preventing distress sales post-harvest.
              </p>
            </div>
          </HoverScale>
        </StaggerItem>
      </StaggerContainer>
    </div>
  </section>

  {/* CTA Section */}
  <section style="padding: 8rem 0; margin-top: 2rem;">
    <div class="container">
      <FadeIn client:visible direction="up">
        <div class="glass" style="padding: 6rem 2rem; text-align: center; background: linear-gradient(145deg, rgba(255, 255, 255, 1) 0%, rgba(240, 253, 244, 1) 100%); border-color: rgba(22, 163, 74, 0.2); position: relative; overflow: hidden; border-radius: 24px;">
          <div style="position: absolute; top: -50px; left: -50px; width: 200px; height: 200px; background: var(--primary-glow); filter: blur(50px); border-radius: 50%; opacity: 0.8; z-index: 0;"></div>
          <div style="position: absolute; bottom: -50px; right: -50px; width: 200px; height: 200px; background: var(--accent-glow); filter: blur(50px); border-radius: 50%; opacity: 0.8; z-index: 0;"></div>
          
          <div style="position: relative; z-index: 2;">
            <h2 class="heading-lg" style="margin-bottom: 1.5rem; color: var(--text-primary);">Ready to digitize agriculture?</h2>
            <p style="color: var(--text-secondary); font-size: 1.15rem; margin-bottom: 2.5rem; max-width: 600px; margin-left: auto; margin-right: auto;">
              We are building the operating system for India's 140M+ agricultural labourers and farmers. Join us in transforming the rural ecosystem.
            </p>
            <HoverScale client:load>
              <a href="/contact" class="btn btn-primary" style="padding: 1.2rem 3rem; font-size: 1.1rem; box-shadow: 0 10px 30px var(--primary-glow);">Join as a Partner</a>
            </HoverScale>
          </div>
        </div>
      </FadeIn>
    </div>
  </section>
</Layout>
