---
import Layout from '../layouts/Layout.astro';
import { Mail, MapPin, Phone } from 'lucide-react';
import { FadeIn, HoverScale } from '../components/ui/Animations';
import { BlobBackground } from '../components/ui/AgriSVGs';
---

<Layout title="Contact Us">
  <section style="padding: 10rem 0 6rem 0; position: relative; overflow: hidden;">
    <BlobBackground client:load />

    <div class="container relative z-10">
      <div class="grid grid-cols-2" style="gap: 4rem;">
        
        <!-- Contact Info -->
        <FadeIn client:load direction="right">
          <h1 class="heading-lg" style="margin-bottom: 1.5rem; color: var(--text-primary);">Join the <span class="text-gradient">Waitlist</span></h1>
          <p style="font-size: 1.2rem; color: var(--text-secondary); margin-bottom: 3rem;">
            Whether you are a farmer looking for reliable labour, an agent managing workers, or a mechanization partner, FarmWork is built for you.
          </p>
          
          <div style="display: flex; flex-direction: column; gap: 2rem;">
            <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
              <HoverScale client:load>
                <div style="width: 56px; height: 56px; border-radius: 16px; background: rgba(22, 163, 74, 0.1); display: flex; align-items: center; justify-content: center; color: var(--primary); flex-shrink: 0; border: 1px solid rgba(22, 163, 74, 0.2);">
                  <Mail size={24} />
                </div>
              </HoverScale>
              <div>
                <h4 style="font-size: 1.2rem; color: var(--text-primary); margin-bottom: 0.25rem;">Email Us</h4>
                <p style="color: var(--text-secondary);">hello@farmwork.in</p>
              </div>
            </div>

            <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
              <HoverScale client:load>
                <div style="width: 56px; height: 56px; border-radius: 16px; background: rgba(22, 163, 74, 0.1); display: flex; align-items: center; justify-content: center; color: var(--primary); flex-shrink: 0; border: 1px solid rgba(22, 163, 74, 0.2);">
                  <Phone size={24} />
                </div>
              </HoverScale>
              <div>
                <h4 style="font-size: 1.2rem; color: var(--text-primary); margin-bottom: 0.25rem;">Call Us</h4>
                <p style="color: var(--text-secondary);">+91 1800-FARM-WRK</p>
              </div>
            </div>

            <div style="display: flex; gap: 1.5rem; align-items: flex-start;">
              <HoverScale client:load>
                <div style="width: 56px; height: 56px; border-radius: 16px; background: rgba(22, 163, 74, 0.1); display: flex; align-items: center; justify-content: center; color: var(--primary); flex-shrink: 0; border: 1px solid rgba(22, 163, 74, 0.2);">
                  <MapPin size={24} />
                </div>
              </HoverScale>
              <div>
                <h4 style="font-size: 1.2rem; color: var(--text-primary); margin-bottom: 0.25rem;">Headquarters</h4>
                <p style="color: var(--text-secondary);">AgriTech Hub, Bangalore, India</p>
              </div>
            </div>
          </div>
        </FadeIn>

        <!-- Contact Form -->
        <FadeIn client:load direction="left" delay={0.2}>
          <div class="glass-card" style="padding: 3rem; background: #ffffff;">
            <form style="display: flex; flex-direction: column; gap: 1.5rem;">
              <div style="display: flex; gap: 1rem;">
                <div style="flex: 1; display: flex; flex-direction: column; gap: 0.5rem;">
                  <label style="color: var(--text-secondary); font-weight: 600; font-size: 0.9rem;">First Name</label>
                  <input type="text" class="form-input" placeholder="Rajesh" />
                </div>
                <div style="flex: 1; display: flex; flex-direction: column; gap: 0.5rem;">
                  <label style="color: var(--text-secondary); font-weight: 600; font-size: 0.9rem;">Last Name</label>
                  <input type="text" class="form-input" placeholder="Kumar" />
                </div>
              </div>
              
              <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                <label style="color: var(--text-secondary); font-weight: 600; font-size: 0.9rem;">Phone Number or Email</label>
                <input type="text" class="form-input" placeholder="+91 9876543210" />
              </div>

              <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                <label style="color: var(--text-secondary); font-weight: 600; font-size: 0.9rem;">I am a...</label>
                <select class="form-input" style="appearance: none;">
                  <option value="farmer">Farmer</option>
                  <option value="agent">Labour Agent / Contractor</option>
                  <option value="partner">Mechanization Partner</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                <label style="color: var(--text-secondary); font-weight: 600; font-size: 0.9rem;">Message (Optional)</label>
                <textarea class="form-input" rows="4" placeholder="Tell us about your requirements..."></textarea>
              </div>

              <HoverScale client:load>
                <button type="button" class="btn btn-primary" style="margin-top: 1rem; width: 100%; padding: 1rem;">Submit Details</button>
              </HoverScale>
            </form>
          </div>
        </FadeIn>

      </div>
    </div>
  </section>
</Layout>

<style>
  @media (max-width: 768px) {
    .grid-cols-2 {
      grid-template-columns: 1fr;
    }
  }
</style>
