---
import Layout from '../layouts/Layout.astro';
import { ArrowUpRight } from 'lucide-react';
import { getPath } from '../utils/paths';
import FeatureTabs from '../components/ui/FeatureTabs';
---

<Layout title="Home | Reimagined">
  
  {/* Full-Width Hero Section */}
  <section class="hero-section" style="min-height: 100vh; padding-top: 10rem; display: flex; flex-direction: column; align-items: center; text-align: center;">
    <div class="container" style="display: flex; flex-direction: column; align-items: center; gap: 3rem;">
      
      {/* Top Typography */}
      <div class="fade-up" style="display: flex; flex-direction: column; align-items: center; width: 100%;">
        
        <h1 class="heading-display" style="margin-bottom: 2rem; line-height: 1.1; white-space: normal; max-width: 1200px;">
          The OS for India's <span style="color: var(--primary);">Agriculture.</span>
        </h1>
        
        <p style="font-size: 1.25rem; color: var(--text-secondary); margin-bottom: 3rem; max-width: 600px; line-height: 1.6;">
          We connect farmers, worker-agents, input and mechanization partners dynamically via one rural operating system.
        </p>
        
      </div>
    </div>

    {/* Absolute Full Width Device Video (Outside Container) */}
    <div class="fade-up delay-1" style="width: 100%; height: clamp(400px, 98vh, 650px); position: relative; margin-top: 4rem; background: #000; overflow: hidden;">
      <video autoplay loop muted playsinline style="width: 100%; height: 100%; object-fit: cover; object-position: bottom; display: block;">
        <source src={getPath("/media/vdo-1.mp4")} type="video/mp4" />
      </video>
    </div>
  </section>

  {/* Community Stakeholders Grid */}
  <section style="padding: 6rem 0; background: #FFFFFF; position: relative; z-index: 2;">
    <div class="container">
      
      {/* Header Block */}
      <div class="community-header grid grid-cols-2" style="margin-bottom: 4rem; align-items: flex-end; gap: 4rem;">
        <div>
          <p style="font-weight: 700; font-size: 0.85rem; letter-spacing: 2px; text-transform: uppercase; color: #d97706; margin-bottom: 1rem;">The Community</p>
          <h2 style="font-family: var(--font-heading); font-size: clamp(2.5rem, 4vw, 3.5rem); font-weight: 900; line-height: 1.1; color: #1c1917; letter-spacing: -0.03em;">
            Four stakeholders.<br />One connected<br />ecosystem.
          </h2>
        </div>
        <div style="padding-bottom: 0.5rem;">
          <p style="font-size: 1.15rem; line-height: 1.7; color: #57534e;">
            Aligning stakeholders through a shared digital thread to turn individual efforts into collective impact.
          </p>
        </div>
      </div>

      {/* 2x2 Cards Grid */}
      <section style="padding: 3rem 0 6rem 0;">
        <div class="fade-up delay-1">
          <FeatureTabs client:load />
        </div>
      </section>
    </div>
  </section>

  <style is:global>
    .stakeholder-card {
      border-radius: 12px;
      padding: 3rem;
      border: 1px solid;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .stakeholder-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 24px rgba(0,0,0,0.03);
    }
    .stakeholder-card .overline {
      font-weight: 800;
      font-size: 0.8rem;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }
    .stakeholder-card h3 {
      font-family: var(--font-heading);
      font-size: 1.75rem;
      font-weight: 800;
      margin-bottom: 2rem;
      letter-spacing: -0.02em;
    }
    .stakeholder-card ul {
      margin: 0;
      padding: 0;
      list-style: none;
    }
    .stakeholder-card ul li {
      position: relative;
      padding-left: 1.5rem;
      margin-bottom: 1rem;
      font-size: 1.05rem;
      color: #334155;
      line-height: 1.5;
    }
    .stakeholder-card ul li::before {
      content: '→';
      position: absolute;
      left: 0;
      color: inherit;
      opacity: 0.4;
      font-weight: 600;
    }
    
    /* Dedicated Color Themes */
    .card-farmers { background: #f3faef; border-color: #dcf2d1; }
    .card-farmers .overline { color: #16a34a; }
    .card-farmers h3 { color: #14532d; }
    .card-farmers ul li::before { color: #16a34a; }
    
    .card-workers { background: #fdf7ee; border-color: #f7e6c6; }
    .card-workers .overline { color: #b45309; }
    .card-workers h3 { color: #78350f; }
    .card-workers ul li::before { color: #b45309; }

    .card-mech { background: #f0f7ff; border-color: #d6e8ff; }
    .card-mech .overline { color: #2563eb; }
    .card-mech h3 { color: #1e3a8a; }
    .card-mech ul li::before { color: #2563eb; }

    .card-input { background: #faf5ff; border-color: #f1e1ff; }
    .card-input .overline { color: #9333ea; }
    .card-input h3 { color: #4c1d95; }
    .card-input ul li::before { color: #9333ea; }

    /* === Homepage Mobile === */
    @media (max-width: 768px) {
      .hero-section {
        padding-top: 7rem !important;
        min-height: unset !important;
      }
      .community-header {
        grid-template-columns: 1fr !important;
        gap: 1.5rem !important;
        margin-bottom: 2rem !important;
      }
      .stakeholder-card {
        padding: 2rem !important;
      }
    }
  </style>

  {/* CTA Area */}
  <section style="padding: 6rem 0; background: var(--text-primary); color: #fff;">
    <div class="container" style="text-align: center;">
      <h2 class="heading-xl" style="color: #fff; margin-bottom: 2rem;">Ready to digitize <br/><span style="color: var(--accent);">agriculture?</span></h2>
      <a href={getPath("/contact")} class="btn" style="background: var(--accent); color: var(--text-primary); padding: 1.5rem 3rem; font-size: 1.25rem; display: inline-flex; width: auto;">
        Join 140M+ Labourers
      </a>
    </div>
  </section>
</Layout>
