---
import Layout from '../layouts/Layout.astro';
import { Tractor, Sprout, Briefcase, BarChart } from 'lucide-react';
import { FadeIn, HoverScale } from '../components/ui/Animations';
import { AnimatedSprout } from '../components/ui/AgriSVGs';
---

<Layout title="Solutions">
  <section style="padding: 10rem 0 4rem 0; text-align: center; position: relative; overflow: hidden;">
    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 500px; background: linear-gradient(180deg, rgba(22,163,74,0.1) 0%, transparent 100%); z-index: -1;"></div>
    
    <div style="position: absolute; top: -20px; right: 15%; opacity: 0.6; z-index: -1;">
      <AnimatedSprout client:load size={150} color="var(--primary)" />
    </div>

    <div class="container">
      <FadeIn client:load direction="up">
        <h1 class="heading-xl" style="margin-bottom: 1.5rem; color: var(--text-primary);">Solutions for <span class="text-gradient">Every Stakeholder</span></h1>
        <p style="font-size: 1.25rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto;">
          From small and marginal farmers to labour agents and input retailers, FarmWork generates mutual value across the chain.
        </p>
      </FadeIn>
    </div>
  </section>

  <!-- Value Propositions Breakdown -->
  <section style="padding: 4rem 0 8rem 0;">
    <div class="container" style="display: flex; flex-direction: column; gap: 6rem;">
      
      <!-- Farmers -->
      <FadeIn client:visible direction="right">
        <div class="glass-card" style="display: grid; grid-template-columns: 1fr 2fr; gap: 3rem; align-items: center; border-color: var(--surface-border); padding: 0; overflow: hidden; background: #ffffff;">
          <div style="position: relative; height: 100%; min-height: 400px; background: rgba(22, 163, 74, 0.05); text-align: center; display: flex; flex-direction: column; justify-content: center; align-items: center;">
            <img src="/media/img-3.jpeg" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.25;" alt="Farmers" />
            <div style="position: absolute; inset: 0; background: linear-gradient(to right, rgba(255,255,255,0.2), rgba(255,255,255,1));"></div>
            <div style="position: relative; z-index: 2;">
              <HoverScale client:load style={{ marginBottom: '1rem' }}>
                <div style="width: 80px; height: 80px; border-radius: 20px; background: #ffffff; border: 1px solid var(--surface-border); box-shadow: 0 10px 30px rgba(0,0,0,0.05); display: flex; align-items: center; justify-content: center; margin: 0 auto;">
                  <Sprout size={40} color="var(--primary)" />
                </div>
              </HoverScale>
              <h2 style="font-size: 2.5rem; color: var(--text-primary); font-family: var(--font-heading);">Farmers</h2>
            </div>
          </div>
          <div style="padding: 3rem 3rem 3rem 0;">
            <h3 style="font-size: 1.8rem; color: var(--primary); margin-bottom: 1.5rem;">On-time labour, cost visibility, markets.</h3>
            <ul style="display: flex; flex-direction: column; gap: 1.5rem;">
              <li style="color: var(--text-secondary); font-size: 1.2rem; display: flex; gap: 1rem;"><span style="color: var(--primary);">✦</span> Affordable mechanization access without needing to purchase expensive machinery.</li>
              <li style="color: var(--text-secondary); font-size: 1.2rem; display: flex; gap: 1rem;"><span style="color: var(--primary);">✦</span> Reliable workforce sourcing precisely during crucial sowing, spraying, and harvesting windows.</li>
              <li style="color: var(--text-secondary); font-size: 1.2rem; display: flex; gap: 1rem;"><span style="color: var(--primary);">✦</span> Build a credible transaction history and output market linkages for better pricing.</li>
            </ul>
          </div>
        </div>
      </FadeIn>

      <!-- Workers -->
      <FadeIn client:visible direction="left">
        <div class="glass-card" style="display: grid; grid-template-columns: 2fr 1fr; gap: 3rem; align-items: center; border-color: var(--surface-border); padding: 0; overflow: hidden; background: #ffffff;">
          <div style="padding: 3rem 0 3rem 3rem;">
            <h3 style="font-size: 1.8rem; color: var(--accent); margin-bottom: 1.5rem;">Consistent work, credit & insurance.</h3>
            <ul style="display: flex; flex-direction: column; gap: 1.5rem;">
              <li style="color: var(--text-secondary); font-size: 1.2rem; display: flex; gap: 1rem;"><span style="color: var(--accent);">✦</span> Visibility into stable, geographically clustered work opportunities.</li>
              <li style="color: var(--text-secondary); font-size: 1.2rem; display: flex; gap: 1rem;"><span style="color: var(--accent);">✦</span> Formal digital records of payouts enabling proof-of-work identity.</li>
              <li style="color: var(--text-secondary); font-size: 1.2rem; display: flex; gap: 1rem;"><span style="color: var(--accent);">✦</span> Direct pathway to formal financial services including credit and farm worker insurance.</li>
            </ul>
          </div>
          <div style="position: relative; height: 100%; min-height: 400px; background: rgba(132, 204, 22, 0.05); text-align: center; display: flex; flex-direction: column; justify-content: center; align-items: center;">
            <img src="/media/img-4.jpeg" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.25;" alt="Workers" />
            <div style="position: absolute; inset: 0; background: linear-gradient(to left, rgba(255,255,255,0.2), rgba(255,255,255,1));"></div>
            <div style="position: relative; z-index: 2;">
              <HoverScale client:load style={{ marginBottom: '1rem' }}>
                <div style="width: 80px; height: 80px; border-radius: 20px; background: #ffffff; border: 1px solid var(--surface-border); box-shadow: 0 10px 30px rgba(0,0,0,0.05); display: flex; align-items: center; justify-content: center; margin: 0 auto;">
                  <Briefcase size={40} color="var(--accent)" />
                </div>
              </HoverScale>
              <h2 style="font-size: 2.5rem; color: var(--text-primary); font-family: var(--font-heading);">Workers</h2>
            </div>
          </div>
        </div>
      </FadeIn>

      <!-- Agents & Retailers -->
      <FadeIn client:visible direction="right">
        <div class="glass-card" style="display: grid; grid-template-columns: 1fr 2fr; gap: 3rem; align-items: center; border-color: var(--surface-border); padding: 0; overflow: hidden; background: #ffffff;">
          <div style="position: relative; height: 100%; min-height: 400px; background: rgba(22, 163, 74, 0.05); text-align: center; display: flex; flex-direction: column; justify-content: center; align-items: center;">
            <img src="/media/img-2.jpeg" style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.25;" alt="Agents & Retailers" />
            <div style="position: absolute; inset: 0; background: linear-gradient(to right, rgba(255,255,255,0.2), rgba(255,255,255,1));"></div>
            <div style="position: relative; z-index: 2;">
              <HoverScale client:load style={{ marginBottom: '1rem' }}>
                <div style="width: 80px; height: 80px; border-radius: 20px; background: #ffffff; border: 1px solid var(--surface-border); box-shadow: 0 10px 30px rgba(0,0,0,0.05); display: flex; align-items: center; justify-content: center; margin: 0 auto;">
                  <BarChart size={40} color="var(--primary)" />
                </div>
              </HoverScale>
              <h2 style="font-size: 2.2rem; color: var(--text-primary); font-family: var(--font-heading); line-height: 1.1;">Agents &<br/>Retailers</h2>
            </div>
          </div>
          <div style="padding: 3rem 3rem 3rem 0;">
            <h3 style="font-size: 1.8rem; color: var(--primary); margin-bottom: 1.5rem;">Pipeline visibility & digitised ledgers.</h3>
            <ul style="display: flex; flex-direction: column; gap: 1.5rem;">
              <li style="color: var(--text-secondary); font-size: 1.2rem; display: flex; gap: 1rem;"><span style="color: var(--primary);">✦</span> <span><strong style="color: var(--text-primary);">Labour Agents:</strong> Unified dashboard for managing pipeline, worker payments, and automatic payroll.</span></li>
              <li style="color: var(--text-secondary); font-size: 1.2rem; display: flex; gap: 1rem;"><span style="color: var(--primary);">✦</span> <span><strong style="color: var(--text-primary);">Mechanization Partners:</strong> Maximize asset utilization by servicing localized clusters easily.</span></li>
              <li style="color: var(--text-secondary); font-size: 1.2rem; display: flex; gap: 1rem;"><span style="color: var(--primary);">✦</span> <span><strong style="color: var(--text-primary);">Input Retailers:</strong> Track sales, maintain purchase histories, and digitize traditional ledgers efficiently.</span></li>
            </ul>
          </div>
        </div>
      </FadeIn>

    </div>
  </section>

  <!-- Moat Statement -->
  <section style="padding: 6rem 0 10rem 0; text-align: center; position: relative;">
    <div class="ambient-glow" style="bottom: 0; left: 50%; transform: translateX(-50%);"></div>
    <div class="container" style="max-width: 800px; position: relative; z-index: 2;">
      <FadeIn client:visible direction="up">
        <h3 style="font-size: 2.5rem; color: var(--text-primary); margin-bottom: 1.5rem; font-family: var(--font-heading);">Our Strategic <span class="text-gradient">Moat</span></h3>
        <p style="font-size: 1.25rem; color: var(--text-secondary); line-height: 1.8;">
          FarmWork is deeply embedded in daily farm operations. Because we collect proprietary worker and farm data across geographical clusters, our platform generates powerful network effects and high switching costs, locking down immense value for all participants.
        </p>
      </FadeIn>
    </div>
  </section>
</Layout>

<style>
  @media (max-width: 768px) {
    .glass-card {
      grid-template-columns: 1fr !important;
    }
    .glass-card > div[style*="padding: 3rem"] {
      padding: 2rem !important;
    }
  }
</style>
