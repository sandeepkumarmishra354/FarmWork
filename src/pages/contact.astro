---
import Layout from "../layouts/Layout.astro";
import { getPath } from "../utils/paths";
---

<Layout
  title="Contact FarmWork | Partnerships, Collaboration & Inquiries"
  description="Get in touch with FarmWork to explore partnership opportunities, ambassador programs, investor conversations, or agritech collaboration."
  canonicalPath="/contact"
  pageType="ContactPage"
  keywords={[
    "contact FarmWork",
    "agritech collaboration India",
    "agriculture partnership inquiry",
    "rural agri startup contact",
    "FarmWork partner inquiry",
    "agritech investor contact India",
    "farm technology partnership",
    "agriculture ambassador program",
    "FarmWork email contact",
    "agri ecosystem collaboration",
  ]}
>

  <div class="contact-page">
    <div class="container">

      <div class="contact-center fade-up">
        <p class="ct-overline">Get in touch</p>
        <h1 class="ct-headline">Let's talk.</h1>
        <p class="ct-sub">Partnership, investment, ambassador program, or just a question — we read every message.</p>
      </div>

      <div class="ct-form-card fade-up" style="animation-delay: 0.15s;">

        <!-- Role Chips -->
        <div class="ct-chips">
          <label class="ct-chip"><input type="radio" name="role" value="partner" /><span>Partner</span></label>
          <label class="ct-chip"><input type="radio" name="role" value="investor" /><span>Investor</span></label>
          <label class="ct-chip"><input type="radio" name="role" value="startup" /><span>Startup</span></label>
          <label class="ct-chip"><input type="radio" name="role" value="ambassador" /><span>Ambassador</span></label>
          <label class="ct-chip"><input type="radio" name="role" value="other" /><span>Other</span></label>
        </div>

        <form class="ct-form" novalidate>
          <div class="ct-row">
            <div class="ct-field">
              <input type="text" id="fname" placeholder=" " required />
              <label for="fname">First Name</label>
              <div class="ct-line"></div>
            </div>
            <div class="ct-field">
              <input type="text" id="lname" placeholder=" " required />
              <label for="lname">Last Name</label>
              <div class="ct-line"></div>
            </div>
          </div>

          <div class="ct-row">
            <div class="ct-field">
              <input type="email" id="email" placeholder=" " required />
              <label for="email">Email</label>
              <div class="ct-line"></div>
            </div>
            <div class="ct-field">
              <input type="text" id="org" placeholder=" " />
              <label for="org">Organisation</label>
              <div class="ct-line"></div>
            </div>
          </div>

          <div class="ct-field">
            <textarea id="message" rows="3" placeholder=" " required></textarea>
            <label for="message">Message</label>
            <div class="ct-line"></div>
          </div>

          <button type="submit" class="ct-submit">
            <span>Send Message</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
            </svg>
          </button>
        </form>

        <div class="ct-footer">
          <a href="mailto:hello@farmworkindia.com" class="ct-email">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            hello@farmworkindia.com
          </a>
          <span class="ct-dot">•</span>
          <span>Based in India</span>
        </div>

      </div>

    </div>
  </div>

</Layout>

<style>
  .contact-page {
    padding: 8rem 0 6rem;
    background: var(--bg-color);
    min-height: 100vh;
  }

  .contact-center {
    text-align: center;
    margin-bottom: 3rem;
  }

  .ct-overline {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--primary);
    margin-bottom: 1rem;
  }

  .ct-headline {
    font-family: var(--font-heading);
    font-size: clamp(2.75rem, 5vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    margin-bottom: 0.75rem;
  }

  .ct-sub {
    font-size: 1.1rem;
    color: var(--text-secondary);
    line-height: 1.5;
    max-width: 460px;
    margin: 0 auto;
  }

  /* ── Form Card ── */
  .ct-form-card {
    max-width: 680px;
    margin: 0 auto;
    background: var(--surface-color);
    border: 1px solid var(--surface-border);
    border-radius: 24px;
    padding: 2.5rem;
    box-shadow: 0 8px 30px rgba(0,0,0,0.03);
  }

  /* ── Chips ── */
  .ct-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .ct-chip {
    cursor: pointer;
    position: relative;
    display: inline-flex;
  }

  .ct-chip input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .ct-chip span {
    display: inline-flex;
    padding: 0.55rem 1rem;
    border-radius: 10px;
    background: var(--bg-color);
    border: 1.5px solid transparent;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ct-chip:hover span {
    background: #e2e8f0;
    color: var(--text-primary);
  }

  .ct-chip input:checked + span {
    background: var(--primary);
    color: #ffffff;
    box-shadow: 0 4px 12px rgba(21, 128, 61, 0.2);
    transform: translateY(-1px);
  }

  /* ── Form ── */
  .ct-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .ct-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .ct-field {
    position: relative;
    background: var(--bg-color);
    border-radius: 12px;
    transition: background 0.3s ease;
  }

  .ct-field:hover {
    background: #f1f5f9;
  }

  .ct-field input,
  .ct-field textarea {
    width: 100%;
    background: transparent;
    border: none;
    padding: 1.3rem 1.15rem 0.55rem;
    font-family: inherit;
    font-size: 0.95rem;
    color: var(--text-primary);
    font-weight: 500;
    outline: none;
    box-sizing: border-box;
  }

  .ct-field textarea {
    resize: vertical;
    min-height: 100px;
  }

  .ct-field label {
    position: absolute;
    left: 1.15rem;
    top: 0.9rem;
    font-size: 0.9rem;
    color: #94a3b8;
    pointer-events: none;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: left top;
  }

  .ct-line {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--primary);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 0 0 12px 12px;
  }

  .ct-field input:focus ~ label,
  .ct-field input:not(:placeholder-shown) ~ label,
  .ct-field textarea:focus ~ label,
  .ct-field textarea:not(:placeholder-shown) ~ label {
    transform: translateY(-0.55rem) scale(0.75);
    color: var(--primary);
    font-weight: 600;
  }

  .ct-field input:focus ~ .ct-line,
  .ct-field textarea:focus ~ .ct-line {
    transform: scaleX(1);
  }

  .ct-field:focus-within {
    background: #ffffff;
    box-shadow: 0 2px 12px rgba(0,0,0,0.03);
  }

  /* ── Submit ── */
  .ct-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    width: 100%;
    padding: 1.1rem;
    margin-top: 0.5rem;
    background: var(--primary);
    color: #ffffff;
    border: none;
    border-radius: 12px;
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 800;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .ct-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(21, 128, 61, 0.25);
  }

  .ct-submit:active {
    transform: translateY(0);
    box-shadow: none;
  }

  /* ── Footer ── */
  .ct-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin-top: 1.5rem;
    font-size: 0.82rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .ct-email {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .ct-email:hover {
    color: var(--primary);
  }

  .ct-dot {
    opacity: 0.3;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .contact-page {
      padding: 6rem 0 4rem;
    }
    .ct-form-card {
      padding: 2rem 1.25rem;
      border-radius: 20px;
    }
    .ct-row {
      grid-template-columns: 1fr;
    }
  }
</style>
